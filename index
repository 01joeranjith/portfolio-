    // PRELOADER LOGIC - Simple & Clean
    window.addEventListener('load', () => {
      setTimeout(() => {
        const preloader = document.getElementById('preloader');
        preloader.style.opacity = '0';
        preloader.style.visibility = 'hidden';
        setTimeout(() => preloader.remove(), 800);
      }, 1800); // Let the simple progress bar complete
    });

    // ACCORDION LOGIC
    function toggleProject(header) {
      const body = header.nextElementSibling;
      const allBodies = document.querySelectorAll('.project-body');
      
      // Optional: Close others
      allBodies.forEach(b => {
        if (b !== body) b.classList.remove('open');
      });
      
      body.classList.toggle('open');
    }

    // GMAIL INTEGRATION
    function sendMail(e) {
      e.preventDefault();
      const name = document.getElementById('cf-name').value.trim();
      const subject = document.getElementById('cf-subject').value.trim();
      const msg = document.getElementById('cf-message').value.trim();
      const body = `Hi Joe,\n\n${msg}\n\nBest regards,\n${name}`;
      
      const gmailLink = `https://mail.google.com/mail/?view=cm&fs=1&to=joeranjith26@gmail.com&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.open(gmailLink, '_blank');
      
      const s = document.getElementById('form-success');
      s.style.display = 'block';
      setTimeout(() => { s.style.display = 'none'; }, 5000);
    }
